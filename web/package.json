{
  "name": "governance-web-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "author": "Ma Yunlong <15500409521@163.com>",
  "scripts": {
    "dev": "pnpm --filter @governance/govern dev",
    "dev:govern": "pnpm --filter @governance/govern dev",
    "dev:web": "pnpm --filter @governance/govern dev",
    "dev:portal": "pnpm --filter @governance/portal dev",
    "build": "pnpm -r --if-present build",
    "build:govern": "pnpm --filter @governance/govern build",
    "build:web": "pnpm --filter @governance/govern build",
    "build:portal": "pnpm --filter @governance/portal build",
    "preview:govern": "pnpm --filter @governance/govern preview",
    "preview:web": "pnpm --filter @governance/govern preview",
    "preview:portal": "pnpm --filter @governance/portal preview",
    "format": "pnpm -r --if-present format"
  },
  "devDependencies": {
    "prettier": "^2.8.7",
    "prettier-plugin-organize-imports": "^3.2.2",
    "prettier-plugin-packagejson": "^2.4.3"
  }
}
